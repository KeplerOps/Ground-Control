#!/usr/bin/env python3
from __future__ import annotations

import argparse
import re
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[1]
PACKAGE_ROOT = "com.keplerops.groundcontrol"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Create an audited entity scaffold.")
    parser.add_argument("domain_area", help="Domain area package, for example controls or assets")
    parser.add_argument("name", help="Entity class name")
    return parser.parse_args()


def next_migration_version() -> int:
    migration_dir = REPO_ROOT / "backend/src/main/resources/db/migration"
    versions = []
    for path in migration_dir.glob("V*__*.sql"):
        match = re.match(r"V(\d+)__", path.name)
        if match:
            versions.append(int(match.group(1)))
    return max(versions, default=0) + 1


def main() -> int:
    args = parse_args()
    area = args.domain_area.strip().replace("-", "").replace("/", ".")
    class_name = args.name.strip()
    package_name = f"{PACKAGE_ROOT}.domain.{area}.model"
    entity_path = (
        REPO_ROOT
        / "backend/src/main/java/com/keplerops/groundcontrol/domain"
        / area.replace(".", "/")
        / "model"
        / f"{class_name}.java"
    )

    entity_path.parent.mkdir(parents=True, exist_ok=True)
    entity_path.write_text(
        f"""package {package_name};

import com.keplerops.groundcontrol.domain.BaseEntity;
import jakarta.persistence.Column;
import jakarta.persistence.Entity;
import jakarta.persistence.Table;
import org.hibernate.envers.Audited;

@Entity
@Audited
@Table(name = "{class_name.lower()}")
public class {class_name} extends BaseEntity {{

    @Column(nullable = false)
    private String name;

    protected {class_name}() {{}}

    public {class_name}(String name) {{
        this.name = name;
    }}

    public String getName() {{
        return name;
    }}
}}
""",
        encoding="utf-8",
    )

    migration_version = next_migration_version()
    print(f"Created {entity_path.relative_to(REPO_ROOT)}")
    print("Next steps:")
    print(f"  - add Flyway migration V{migration_version:03d}__create_{class_name.lower()}.sql")
    print(f"  - add Flyway migration V{migration_version + 1:03d}__create_{class_name.lower()}_audit.sql")
    print("  - add @NotAudited on any @ManyToOne fields that point at non-audited entities")
    print("  - update MigrationSmokeTest.java and RequirementsE2EIntegrationTest.java")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
