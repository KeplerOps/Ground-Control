#!/usr/bin/env python3
from __future__ import annotations

import argparse
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[1]
PACKAGE_ROOT = "com.keplerops.groundcontrol"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Create a controller + @WebMvcTest scaffold.")
    parser.add_argument("feature", help="API feature package, for example requirements or controls")
    parser.add_argument("name", help="Controller base name without the Controller suffix")
    return parser.parse_args()


def write(path: Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")


def main() -> int:
    args = parse_args()
    feature = args.feature.strip().replace("-", "").replace("/", ".")
    class_name = f"{args.name}Controller"
    test_name = f"{class_name}Test"
    package_name = f"{PACKAGE_ROOT}.api.{feature}"

    controller_path = (
        REPO_ROOT
        / "backend/src/main/java/com/keplerops/groundcontrol/api"
        / feature.replace(".", "/")
        / f"{class_name}.java"
    )
    test_path = (
        REPO_ROOT
        / "backend/src/test/java/com/keplerops/groundcontrol/unit/api"
        / f"{test_name}.java"
    )

    write(
        controller_path,
        f"""package {package_name};

import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

@RestController
@RequestMapping("/api/v1/{args.feature}")
public class {class_name} {{}}
""",
    )

    write(
        test_path,
        f"""package {PACKAGE_ROOT}.unit.api;

import {package_name}.{class_name};
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.WebMvcTest;
import org.springframework.test.web.servlet.MockMvc;

@WebMvcTest({class_name}.class)
class {test_name} {{

    @Autowired
    private MockMvc mockMvc;

    @Test
    void contextLoads() {{}}
}}
""",
    )

    print(f"Created {controller_path.relative_to(REPO_ROOT)}")
    print(f"Created {test_path.relative_to(REPO_ROOT)}")
    print("Next steps:")
    print("  - update docs/API.md")
    print("  - update mcp/ground-control/lib.js and mcp/ground-control/index.js")
    print("  - replace the placeholder route and add real assertions to the WebMvcTest")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
