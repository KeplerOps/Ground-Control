#!/usr/bin/env python3
from __future__ import annotations

import argparse
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[1]
PACKAGE_ROOT = "com.keplerops.groundcontrol"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Create an L2 state machine scaffold.")
    parser.add_argument("domain_area", help="Domain area package, for example requirements")
    parser.add_argument("name", help="Enum name")
    return parser.parse_args()


def write(path: Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")


def main() -> int:
    args = parse_args()
    area = args.domain_area.strip().replace("-", "").replace("/", ".")
    enum_name = args.name.strip()
    package_name = f"{PACKAGE_ROOT}.domain.{area}.state"
    enum_path = (
        REPO_ROOT
        / "backend/src/main/java/com/keplerops/groundcontrol/domain"
        / area.replace(".", "/")
        / "state"
        / f"{enum_name}.java"
    )
    test_path = (
        REPO_ROOT
        / "backend/src/test/java/com/keplerops/groundcontrol/unit/domain"
        / f"{enum_name}PropertyTest.java"
    )
    tla_path = REPO_ROOT / "specs/tla" / f"{enum_name}.tla"

    write(
        enum_path,
        f"""package {package_name};

import java.util.EnumMap;
import java.util.EnumSet;
import java.util.Map;
import java.util.Set;

public enum {enum_name} {{
    DRAFT,
    ACTIVE,
    ARCHIVED;

    private static final Map<{enum_name}, Set<{enum_name}>> VALID_TRANSITIONS = new EnumMap<>({enum_name}.class);

    static {{
        VALID_TRANSITIONS.put(DRAFT, EnumSet.of(ACTIVE));
        VALID_TRANSITIONS.put(ACTIVE, EnumSet.of(ARCHIVED));
        VALID_TRANSITIONS.put(ARCHIVED, EnumSet.noneOf({enum_name}.class));
    }}

    public boolean canTransitionTo({enum_name} other) {{
        return VALID_TRANSITIONS.getOrDefault(this, Set.of()).contains(other);
    }}
}}
""",
    )

    write(
        test_path,
        f"""package {PACKAGE_ROOT}.unit.domain;

import static org.assertj.core.api.Assertions.assertThat;

import {package_name}.{enum_name};
import net.jqwik.api.ForAll;
import net.jqwik.api.Property;
import org.junit.jupiter.api.Tag;

@Tag("slow")
class {enum_name}PropertyTest {{

    @Property
    void archivedHasNoOutgoingTransitions(@ForAll {enum_name} state) {{
        if (state == {enum_name}.ARCHIVED) {{
            assertThat(state.canTransitionTo({enum_name}.DRAFT)).isFalse();
            assertThat(state.canTransitionTo({enum_name}.ACTIVE)).isFalse();
        }}
    }}
}}
""",
    )

    write(
        tla_path,
        f"""---- MODULE {enum_name} ----
EXTENDS Naturals, Sequences

CONSTANTS DRAFT, ACTIVE, ARCHIVED

VARIABLE state

Init == state = DRAFT

Next ==
    \\/ /\\ state = DRAFT
       /\\ state' = ACTIVE
    \\/ /\\ state = ACTIVE
       /\\ state' = ARCHIVED

====
""",
    )

    print(f"Created {enum_path.relative_to(REPO_ROOT)}")
    print(f"Created {test_path.relative_to(REPO_ROOT)}")
    print(f"Created {tla_path.relative_to(REPO_ROOT)}")
    print("Next steps:")
    print("  - replace placeholder states and transitions")
    print("  - add jqwik properties for reachability and illegal transitions")
    print("  - wire the new TLA+ spec into your verification workflow")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
