#!/usr/bin/env python3
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from tools.policy.checks import read_changed_files, render_and_exit, run_adr_guard


def main(argv: list[str] | None = None) -> int:
    args = argv or sys.argv[1:]
    changed_files = read_changed_files(files=args)
    return render_and_exit(run_adr_guard(changed_files))


if __name__ == "__main__":
    raise SystemExit(main())
