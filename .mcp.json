{
  "mcpServers": {
    "ground-control": {
      "type": "stdio",
      "command": "node",
      "args": ["/home/atomik/src/Ground-Control/mcp/ground-control/index.js"],
      "env": {
        "GH_REPO": "KeplerOps/Ground-Control"
      }
    },
    "sonarqube": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--init",
        "--pull=always",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_ORG",
        "mcp/sonarqube"
      ],
      "env": {
        "SONARQUBE_TOKEN": "${SONAR_TOKEN}",
        "SONARQUBE_ORG": "KeplerOps"
      }
    }
  }
}
