{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path // empty'); if [ -n \"$FILE\" ] && echo \"$FILE\" | grep -q '\\.java$'; then cd /home/atomik/src/Ground-Control/backend && ./gradlew spotlessApply -q 2>/dev/null; fi",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "/home/atomik/src/Ground-Control/.claude/hooks/log-skill-call.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/atomik/src/Ground-Control/.claude/hooks/verify-implementation.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
