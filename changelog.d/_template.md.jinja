{# Towncrier template — emits Keep-a-Changelog-style release sections.
   Consumed by `towncrier build` at release time. The header line below is
   matched by the Step 6 completion-gate "documentation set" check and by
   `tools/policy/checks.py`. #}
{% if top_line %}
{{ top_line }}
{% elif versiondata.name %}
## [{{ versiondata.version }}] - {{ versiondata.date }}
{% else %}
## [{{ versiondata.version }}] - {{ versiondata.date }}
{% endif %}
{% for section_name, _ in sections.items() %}
{% if sections[section_name] %}
{% for category, val in definitions.items() if category in sections[section_name] %}
### {{ definitions[category]['name'] }}
{% if definitions[category]['showcontent'] %}
{% for text, values in sections[section_name][category].items() %}
- {{ text }}{% if values %} {{ values|join(", ") }}{% endif %}

{% endfor %}
{% else %}
- {{ sections[section_name][category]['']|join(', ') }}

{% endif %}
{% endfor %}
{% else %}
No significant changes.

{% endif %}
{% endfor %}
