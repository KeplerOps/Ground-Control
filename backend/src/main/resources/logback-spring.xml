<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console appender for dev (human-readable) -->
    <springProfile name="!prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- JSON appender for production (machine-parseable) -->
    <springProfile name="prod">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"service.name":"ground-control","service.version":"0.19.0"}</customFields>
                <includeMdcKeyName>request_id</includeMdcKeyName>
                <includeMdcKeyName>tenant_id</includeMdcKeyName>
                <includeMdcKeyName>actor_id</includeMdcKeyName>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
    </springProfile>

</configuration>
