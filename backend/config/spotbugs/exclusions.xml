<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude JPA metamodel generated classes -->
    <Match>
        <Class name="~.*_$" />
    </Match>

    <!-- Exclude test code -->
    <Match>
        <Source name="~.*Test\.java" />
    </Match>
    <Match>
        <Source name="~.*Tests\.java" />
    </Match>

    <!-- JPA entities use mutable fields by design -->
    <Match>
        <Package name="~com\.keplerops\.groundcontrol\.domain\..*\.model" />
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2" />
    </Match>

    <!-- Records expose fields via accessors by design -->
    <Match>
        <Package name="~com\.keplerops\.groundcontrol\.api.*" />
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2" />
    </Match>

    <!-- Spring services store injected dependencies by design -->
    <Match>
        <Package name="~com\.keplerops\.groundcontrol\.domain\..*\.service" />
        <Bug pattern="EI_EXPOSE_REP2" />
    </Match>

    <!-- Infrastructure components store injected dependencies by design -->
    <Match>
        <Package name="~com\.keplerops\.groundcontrol\.infrastructure\..*" />
        <Bug pattern="EI_EXPOSE_REP2" />
    </Match>

    <!-- Constructors that validate inputs and throw are by-design -->
    <Match>
        <Package name="~com\.keplerops\.groundcontrol\.domain\.exception" />
        <Bug pattern="CT_CONSTRUCTOR_THROW" />
    </Match>
    <Match>
        <Package name="~com\.keplerops\.groundcontrol\.domain\..*\.model" />
        <Bug pattern="CT_CONSTRUCTOR_THROW" />
    </Match>

    <!-- Spring-managed service that validates wiring at construction time -->
    <Match>
        <Class name="com.keplerops.groundcontrol.domain.packregistry.service.PackTypeHandlerRegistry" />
        <Bug pattern="CT_CONSTRUCTOR_THROW" />
    </Match>

    <!-- Envers revision entity inherits correct equals from DefaultRevisionEntity -->
    <Match>
        <Class name="com.keplerops.groundcontrol.domain.audit.GroundControlRevisionEntity" />
        <Bug pattern="EQ_DOESNT_OVERRIDE_EQUALS" />
    </Match>

    <!-- Service-layer records that hold entity references are read-only audit snapshots -->
    <Match>
        <Package name="~com\.keplerops\.groundcontrol\.domain\..*\.service" />
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>
</FindBugsFilter>
